# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.venv/
venv/
*.whl

# Node
node_modules/
.next/
out/
.turbo/

# Testing
.pytest_cache/
.coverage
htmlcov/
.storybook-out/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Environment
.env
.env.*
!.env.example

# AKB config (yaml — single source of runtime config; only .example is tracked)
/config/*.yaml
/config/*.bak
!/config/*.yaml.example
# Test-bootstrap copy of app.yaml — materialised by backend/tests/conftest.py
# so `app.config` can import when pytest runs from `backend/` (CWD-relative
# config search misses the repo-root /config without it).
/backend/config/

# Operator-specific deploy overrides — internal hostnames, registry,
# ClusterIssuers with real DNS-01 credentials, etc. The base manifests
# under deploy/k8s/ stay generic; private overrides live here.
/deploy/k8s/internal/

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Claude Code
.claude/

# AI-assistant scratch — superpowers skill writes plans/specs here by default.
# Keep the design assets at docs/design/ (curated) and let the working
# directory stay local-only.
/docs/superpowers/

# Docker
*.log

# Data (local dev)
/data/
.playwright-mcp/
