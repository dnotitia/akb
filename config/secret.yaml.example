# AKB secrets. Copy to `secret.yaml` and fill in.
# This file MUST stay out of source control (.gitignore excludes it).

# === Database ===
# Local docker-compose convenience value. Must match POSTGRES_PASSWORD
# in docker-compose.yaml. Change both for any non-local deploy.
db_password: akb

# === JWT — signs auth tokens. ===
# REPLACE before any non-local deploy. Generate one:  openssl rand -hex 32
jwt_secret: dev-only-change-me-before-deploying-anywhere-real

# === Embedding API key (required) ===
# Provider key for `embed_base_url` in app.yaml.
embed_api_key: ""

# === LLM API key (optional) ===
# Only needed if `llm_base_url` in app.yaml is set.
llm_api_key: ""

# === Reranker API key (optional) ===
# Only needed if `rerank_enabled: true`. Blank → falls back to llm_api_key.
rerank_api_key: ""

# === S3 credentials (optional) ===
# Only needed if `s3_endpoint_url` in app.yaml is set.
s3_access_key: ""
s3_secret_key: ""

# === Vector store API key (optional) ===
# Only needed if Qdrant is configured with an API key (not the default).
vector_api_key: ""

# === Redis password (optional) ===
# Only needed if `redis_url` in app.yaml is set. Must match the password
# baked into the Redis Secret on the Redis side (deploy/k8s/redis.yaml).
redis_password: ""
